---
import Base from "../../layouts/Base.astro";
import { loadCatalogue, sanitizeCatalogueText } from "../../lib/catalogue";
import windowsData from "../../data/windows.json";

interface WindowEntry {
  id: string;
  name: string;
  period_years: number | null;
  primary: string;
  trajectory_regime: string;
  bodies: string[];
  next_encounters_iso: string[];
  vinf_actual_kms: number[][];
  c3_km2_s2: (number | null)[];
  mismatch_kms: number[];
  tof_first_leg_days: number | null;
  maintenance_dv_kms: number | null;
  maintenance_dv_status?: string;
  status: string;
}

interface WindowsData {
  generated_at: string;
  method: string;
  horizon_start: string;
  horizon_end: string;
  horizon_years: number;
  n_per_cycler: number;
  step_days: number;
  mismatch_cap_kms: number;
  maintenance_dv_computed?: boolean;
  schema_note?: string;
  disclaimer: string;
  entries: WindowEntry[];
}

const data = windowsData as WindowsData;
const catalogue = loadCatalogue();

// Sort entries: ones with windows first, then by id.
const withWindows = data.entries.filter((e) => e.next_encounters_iso.length > 0);
const withoutWindows = data.entries.filter((e) => e.next_encounters_iso.length === 0);

function formatDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString("en-CA"); // YYYY-MM-DD
}

function formatVinf(vinf: number[]): string {
  return vinf.map((v) => v.toFixed(2)).join(" / ");
}

// Windows are stored best-match-first; show them earliest-date first while
// keeping each date's V∞ and C₃ aligned. ISO YYYY-MM-DD sorts as a string.
function sortedWindows(e: WindowEntry) {
  return e.next_encounters_iso
    .map((iso, i) => ({ iso, vinf: e.vinf_actual_kms[i], c3: e.c3_km2_s2?.[i] ?? null }))
    .sort((a, b) => a.iso.localeCompare(b.iso));
}

const nWithWindows = withWindows.length;
const nTotal = data.entries.length;
---
<Base title="Launch windows" description="Real-ephemeris launch windows for each catalogued ballistic cycler.">
  <h1>Launch windows</h1>

  <div class="banner">
    <strong>Real ephemeris, geometric match only.</strong> Dates below are real and verifiable —
    they come from astropy + JPL DE440 + a Lambert solve at each candidate date,
    keeping the dates whose V<sub>∞</sub> at injection matches the cycler's signature.
    <strong>Now shown:</strong> C<sub>3</sub> at departure (= |V<sub>∞,depart</sub>|², per
    window) and time-of-flight to the first encounter (per cycler) — both derived directly
    from the same Lambert solve / phase signature the dates come from — plus the
    <strong>maintenance-ΔV (TCM) budget</strong> for closed E–M (Aldrin-style) cyclers:
    <strong>2.91 km/s</strong>, computed by the upstream optimiser and cross-checked
    against an independent solver (<a href="#maintenance-dv">how that value was earned</a>,
    including the wrong answer it replaced, is documented below).
  </div>

  <p>
    Horizon: <strong>{data.horizon_start}</strong> → <strong>{data.horizon_end}</strong>
    ({data.horizon_years} years). Generated <strong>{formatDate(data.generated_at)}</strong>;
    refreshes weekly. Grid resolution {data.step_days} d; V<sub>∞</sub> mismatch cap
    {data.mismatch_cap_kms} km/s. Per-cycler window count: up to {data.n_per_cycler}.
  </p>

  <p class="muted">
    {nWithWindows} of {nTotal} catalogue entries produced launch windows. The remaining
    {nTotal - nWithWindows} were skipped — non-ballistic, non-heliocentric, lacking the
    orbital data needed to reconstruct a phase signature, or no geometric match found
    inside the horizon at the current mismatch cap.
  </p>

  <h2>Cyclers with launch windows in the horizon</h2>

  <table class="catalogue">
    <thead>
      <tr>
        <th scope="col">Cycler</th>
        <th scope="col">Bodies</th>
        <th scope="col">Period (yr)</th>
        <th scope="col">TOF 1st leg (d)</th>
        <th scope="col">Next windows (date · V<sub>∞</sub> km/s · C<sub>3</sub> km²/s²)</th>
        <th scope="col">Maint. ΔV (km/s)</th>
        <th scope="col">Mismatch</th>
      </tr>
    </thead>
    <tbody>
      {withWindows.map((e) => (
        <tr>
          <td><a href={`/cycler/${e.id}/`}>{sanitizeCatalogueText(e.name)}</a></td>
          <td>{e.bodies.join(",")}</td>
          <td class="right">{e.period_years?.toFixed(2) ?? "—"}</td>
          <td class="right">{e.tof_first_leg_days?.toFixed(0) ?? "—"}</td>
          <td>
            <ul class="window-dates">
              {sortedWindows(e).map((w) => (
                <li>
                  <strong>{w.iso}</strong>
                  <span class="muted"> · V<sub>∞</sub> {formatVinf(w.vinf)}</span>
                  <span class="muted"> · C<sub>3</sub> {w.c3 != null ? w.c3.toFixed(1) : "—"}</span>
                </li>
              ))}
            </ul>
          </td>
          <td class="right muted">{e.maintenance_dv_kms != null ? e.maintenance_dv_kms.toFixed(2) : "—"}</td>
          <td class="right muted">
            {e.mismatch_kms.length > 0 ? Math.min(...e.mismatch_kms).toFixed(2) : "—"}
          </td>
        </tr>
      ))}
    </tbody>
  </table>

  {withoutWindows.length > 0 && (
    <>
      <h2>Cyclers without windows (skipped or no match)</h2>
      <table class="catalogue">
        <thead>
          <tr>
            <th scope="col">Cycler</th>
            <th scope="col">Reason</th>
          </tr>
        </thead>
        <tbody>
          {withoutWindows.map((e) => (
            <tr>
              <td><a href={`/cycler/${e.id}/`}>{sanitizeCatalogueText(e.name)}</a></td>
              <td class="muted">{sanitizeCatalogueText(e.status)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  )}

  <h2>What's shown now, and what's still deferred</h2>
  <p>
    <strong>C<sub>3</sub> at departure</strong> and <strong>TOF to first encounter</strong>
    are now wired into the weekly export: both are cheap by-products of the existing
    geometric-match Lambert solve (C<sub>3</sub> = |V<sub>∞</sub>|² at the departure body;
    the first-leg ToF is read straight off the cycler's phase signature), so they add no
    runtime to the cron job.
  </p>
  <p id="maintenance-dv">
    The <strong>maintenance-ΔV budget</strong> is populated for closed E–M (Aldrin-style)
    cyclers — <strong>2.91 km/s</strong> — but getting there took catching a bug. The
    upstream optimiser (M6b,
    <code>cyclerfinder.search.maintain.optimise_aldrin_maintenance_dv</code>) is a global
    <code>differential_evolution</code> + multi-start SLSQP run over real DE440 states; one
    closed E–M–E solve measures ~12–19 s, driven through a row-level parallel batch
    (<code>scripts/maintenance_batch.py</code>, a <code>ProcessPoolExecutor</code> over rows,
    each worker building its own ephemeris).
    <strong>The catch:</strong> the default phase seed is tuned to the idealised circular
    ephemeris, and on real DE440 it is mis-phased — the global search slid onto an
    <em>off-family</em> degenerate basin reporting 55.3 km/s, far above the
    <code>&lt;3 km/s</code> plausibility bar and the 1.29 km/s in-family circular-model
    value. The column was held blank rather than publish a degenerate solve labelled as a
    TCM budget.
    <strong>The fix:</strong> seed the DE440 solve from the real launch window whose Lambert
    V<sub>∞</sub> best matches the sourced Aldrin anchors (V<sub>∞,E</sub> 6.5,
    V<sub>∞,M</sub> 9.7 km/s) — the same V<sub>∞</sub>-mismatch resolver the M6b real-closure
    path uses. That lands in-family (a ≈ 1.59 AU, e ≈ 0.39, V<sub>∞</sub> 6.4 / 9.5 km/s) at
    <strong>2.91 km/s</strong>, a value the independent powered-cycler BVP solver reproduces
    exactly. Because the solve takes no row-specific input, every closed E–M row resolves to
    that same Aldrin ΔV; the batch computes it once and broadcasts it. Rows whose
    <code>bodies</code> are not <code>["E","M"]</code> stay null — the optimiser needs a
    closed sequence plus an Earth-closure flyby config the open-chain rows don't yet supply
    (<code>maintenance_dv_status</code> records the reason per row).
  </p>
  <p class="muted">
    <strong>Now codified, not caught by hand.</strong> That 55.3 km/s value was originally
    caught only by a manual cross-check. The exporter now runs every computed ΔV through a
    publication-layer plausibility gate
    (<code>cyclerfinder.verify.plausibility.check_publishable</code>): a value above the
    &lt;3 km/s engineering bar is <em>refused</em> — recorded as
    <code>maintenance_dv_status: "refused: …"</code> with the reason, never written as a ΔV.
    The same module enforces a hard <em>physics</em> ceiling on V<sub>∞</sub> (a periodic
    heliocentric orbit cannot exceed v<sub>esc,☉</sub>(r) + v<sub>body</sub>, ≈ 71.9 km/s at
    Earth), distinct from the engineering bar.
  </p>
  <p class="muted">
    <strong>Why it isn't on the weekly cron.</strong> Even parallelised, the cold-cache DE440
    solve is too slow for GitHub's free runner (2–4 cores), and the value is row-invariant, so
    a weekly recompute buys nothing. The column is computed once with
    <code>python scripts/compute_windows.py --maintenance-dv</code> and committed; the cron runs
    with <code>--preserve-maintenance-dv</code>, which carries the existing values forward so a
    dates refresh never nulls the column. Re-run the opt-in command locally to refresh it.
  </p>

  <h2>How the dates are computed</h2>
  <p>
    For each ballistic, heliocentric, Earth-touching cycler in the
    <a href="/catalogue/">catalogue</a>: the cycler's per-encounter V<sub>∞</sub>
    targets and per-leg time-of-flight are extracted as a <em>phase signature</em>. We then
    grid-scan the next {data.horizon_years} years of real ephemeris at {data.step_days} d resolution; at each
    candidate departure date we solve the Lambert two-point boundary-value problem between
    Earth's actual position and Mars's (or the relevant body's) actual position at the
    cycler's leg ToF. The candidate's "mismatch" is the sum of <em>|V<sub>∞</sub><sub>,actual</sub>
    − V<sub>∞</sub><sub>,target</sub>|</em> across encounters. The N lowest-mismatch dates
    below the {data.mismatch_cap_kms} km/s cap are kept, shown earliest-date first.
  </p>

  <p class="muted">
    Source: <code>cyclerfinder.search.phase_match.find_real_windows</code> in the upstream
    repo. Ephemeris: JPL DE440 via astropy. Refresh cadence: weekly cron in
    <code>.github/workflows/refresh-windows.yml</code>; also triggers on workflow_dispatch.
  </p>
</Base>

<style>
  ul.window-dates {
    margin: 0;
    padding-left: 1em;
    font-size: 0.92em;
  }
  /* Keep each "date · V∞ …" entry on one line so the column takes its
     natural width (the table scrolls horizontally on narrow screens). */
  ul.window-dates li {
    white-space: nowrap;
  }
</style>
