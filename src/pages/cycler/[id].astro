---
import Base from "../../layouts/Base.astro";
import { loadCatalogue, fmt, fmtBodies, legsOf, isFullyDefined } from "../../lib/catalogue";
import type { CyclerEntry, Citation } from "../../lib/types";

const CLS_LABEL: Record<string, string> = {
  "single-ellipse": "single-ellipse",
  "multi-arc": "multi-arc",
  "non-keplerian": "non-keplerian (CR3BP)",
};

export function getStaticPaths() {
  return loadCatalogue().map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CyclerEntry;
}

const { entry } = Astro.props;
const legs = legsOf(entry);
const fullyDefined = isFullyDefined(entry);
const dataGaps = entry.data_gaps ?? [];

const formatCite = (c: Citation): string => {
  const authors =
    c.authors.length === 1
      ? c.authors[0]!
      : c.authors.length === 2
        ? `${c.authors[0]} & ${c.authors[1]}`
        : `${c.authors[0]} et al.`;
  return `${authors} (${c.year}). ${c.title}. ${c.venue}.`;
};
---
<Base title={entry.name} description={`Cycler catalogue entry: ${entry.name}`}>
  <p><a href="/catalogue/">&larr; Catalogue</a></p>

  <h1>{entry.name}</h1>
  <p class="muted">
    <code>{entry.id}</code> &middot; source: <strong>{entry.source}</strong> &middot;
    validation: <span class="vlevel">{entry.validation_level ?? "V0"}</span>
  </p>

  <h2>Signature</h2>
  <dl class="cycler">
    <dt>Bodies</dt><dd>{fmtBodies(entry.bodies)}</dd>
    <dt>Primary</dt>
    <dd>
      {entry.primary ?? "Sun"}
      {!entry.primary && <span class="muted"> (default — heliocentric)</span>}
    </dd>
    <dt>Sequence (canonical)</dt><dd><code>{entry.sequence_canonical}</code></dd>
    <dt>Sense</dt><dd>{entry.sense}</dd>
    <dt>Cycler class</dt>
    <dd>
      <span class={`cls-badge cls-${(entry.cycler_class ?? "single-ellipse").replace("-", "")}`}>
        {CLS_LABEL[entry.cycler_class ?? "single-ellipse"] ?? (entry.cycler_class ?? "single-ellipse")}
      </span>
    </dd>
    <dt>Trajectory regime</dt>
    <dd>
      {entry.trajectory_regime ?? "ballistic"}
      {!entry.trajectory_regime && <span class="muted"> (default)</span>}
    </dd>
    <dt>Model assumption</dt>
    <dd>
      {entry.model_assumption ?? "circular-coplanar"}
      {!entry.model_assumption && <span class="muted"> (default)</span>}
      <div class="muted" style="font-size:0.85em">
        {entry.model_assumption === "cr3bp" && "CR3BP — Jacobi-constant-conserved; signature not patched-conic comparable."}
        {entry.model_assumption === "analytic-ephemeris" && "Mid-fidelity: real eccentricity / inclination retained; not full N-body."}
        {(!entry.model_assumption || entry.model_assumption === "circular-coplanar") && "Idealised: planets on circles, coplanar ecliptic."}
      </div>
    </dd>
    <dt>Period</dt>
    <dd>
      {fmt(entry.period.years, 3)} yr ({entry.period.k} × {entry.period.pair} synodic)
      {entry.period.note && <div class="muted">{entry.period.note}</div>}
    </dd>
    {entry.delta_v_kms !== undefined && entry.delta_v_kms !== null && (
      <>
        <dt>Maintenance ΔV</dt>
        <dd>
          {entry.delta_v_kms === 0 ? (
            <span>0 km/s <span class="muted">— strict ballistic</span></span>
          ) : (
            <span>{fmt(entry.delta_v_kms, 3)} km/s <span class="muted">— near-ballistic (powered nudge)</span></span>
          )}
        </dd>
      </>
    )}
    {entry.v_infinity_leveraging_dv_kms !== undefined && entry.v_infinity_leveraging_dv_kms !== null && (
      <>
        <dt>V<sub>∞</sub> leveraging ΔV (establishment)</dt>
        <dd>{fmt(entry.v_infinity_leveraging_dv_kms, 3)} km/s</dd>
      </>
    )}
    {entry.fleet_size !== undefined && entry.fleet_size !== null && (
      <><dt>Fleet size</dt><dd>{entry.fleet_size} vehicles</dd></>
    )}
    <dt>Priority date</dt><dd>{entry.priority_date}</dd>
  </dl>

  <h2>V∞ at encounters</h2>
  {entry.vinf_kms_at_encounters.length === 0 ? (
    <p class="muted">No encounter V∞ values published in accessible sources.</p>
  ) : (
    <dl class="cycler">
      {entry.vinf_kms_at_encounters.map((v, i) => (
        <>
          <dt>{v.body} (#{i + 1})</dt>
          <dd>
            {v.vinf_kms === null ? <span class="muted">— (not published)</span> : <>{fmt(v.vinf_kms, 2)} km/s</>}
            {v.note && <div class="muted">{v.note}</div>}
          </dd>
        </>
      ))}
    </dl>
  )}

  {(entry.cycler_class ?? "single-ellipse") === "single-ellipse" && (
    <>
      <h2>Orbit elements (heliocentric)</h2>
      <dl class="cycler">
        <dt>Semi-major axis a</dt><dd>{fmt(entry.orbit_elements.a_au, 3)} AU</dd>
        <dt>Eccentricity e</dt><dd>{fmt(entry.orbit_elements.e, 3)}</dd>
        <dt>Perihelion</dt><dd>{fmt(entry.orbit_elements.perihelion_au, 3)} AU</dd>
        <dt>Aphelion</dt><dd>{fmt(entry.orbit_elements.aphelion_au, 3)} AU</dd>
        <dt>Inclination</dt><dd>{fmt(entry.orbit_elements.inclination_deg, 2)}°</dd>
      </dl>
      {entry.orbit_elements.note && <p class="muted">{entry.orbit_elements.note}</p>}
    </>
  )}

  {(entry.cycler_class === "multi-arc") && (
    <>
      <h2>Cycle-level identity (multi-arc invariants)</h2>
      {entry.invariants ? (
        <dl class="cycler">
          <dt>Aphelion ratio (AR)</dt>
          <dd>{fmt(entry.invariants.aphelion_ratio, 2)}</dd>
          <dt>Turn ratio (TR)</dt>
          <dd>{fmt(entry.invariants.turn_ratio, 2)}</dd>
          <dt>Transit times (days)</dt>
          <dd>
            {entry.invariants.transit_times_days && entry.invariants.transit_times_days.length > 0
              ? entry.invariants.transit_times_days.map((t) => `${t} d`).join(", ")
              : <span class="muted">—</span>
            }
          </dd>
        </dl>
      ) : (
        <p class="muted">No invariants block recorded for this entry.</p>
      )}
      {entry.orbit_elements.note && <p class="muted">{entry.orbit_elements.note}</p>}
    </>
  )}

  {(entry.cycler_class === "non-keplerian") && (
    <>
      <h2>CR3BP orbit identity</h2>
      {entry.orbit_elements.cr3bp ? (
        <dl class="cycler">
          {entry.orbit_elements.cr3bp.family && (
            <><dt>Family</dt><dd>{entry.orbit_elements.cr3bp.family}</dd></>
          )}
          {entry.orbit_elements.cr3bp.mass_ratio !== null && entry.orbit_elements.cr3bp.mass_ratio !== undefined && (
            <><dt>Mass ratio (μ)</dt><dd>{entry.orbit_elements.cr3bp.mass_ratio}</dd></>
          )}
          {entry.orbit_elements.cr3bp.libration_point && (
            <><dt>Libration point</dt><dd>{entry.orbit_elements.cr3bp.libration_point}</dd></>
          )}
          <dt>Jacobi constant</dt>
          <dd>{fmt(entry.orbit_elements.cr3bp.jacobi_constant, 4)}</dd>
          <dt>Period (non-dim)</dt>
          <dd>{fmt(entry.orbit_elements.cr3bp.period_nd, 4)}</dd>
          <dt>Stability index</dt>
          <dd>{fmt(entry.orbit_elements.cr3bp.stability_index, 3)}</dd>
        </dl>
      ) : (
        <p class="muted">No CR3BP identity block recorded for this entry.</p>
      )}
      {entry.orbit_elements.note && <p class="muted">{entry.orbit_elements.note}</p>}
    </>
  )}

  {legs.length > 0 && (
    <>
      <h2>Legs{entry.trajectory ? " (trajectory segments)" : ""}</h2>
      <ul class="bare">
        {legs.map((leg) => (
          <li>
            <code>{leg.from} → {leg.to}</code>:
            {leg.tof_days === null ? " (TOF not published)" : ` ${leg.tof_days} d, ${leg.n_revs} revs`}
            {leg.note && <div class="muted">{leg.note}</div>}
          </li>
        ))}
      </ul>
    </>
  )}

  <h2>Definition status</h2>
  <p>
    <span class={fullyDefined ? "vlevel" : "vlevel muted"}>
      {fullyDefined ? "fully defined" : "incomplete"}
    </span>
    {!fullyDefined && (
      <span class="muted"> — core fields missing or known-unknowns tracked below</span>
    )}
  </p>
  {entry.family && (
    <p class="muted">
      Family: <strong>{entry.family.name ?? entry.family.id}</strong>
      {entry.family.nomenclature && <> &middot; {entry.family.nomenclature}</>}
    </p>
  )}
  {dataGaps.length > 0 && (
    <>
      <h3>Known-unknowns ({dataGaps.length})</h3>
      <p class="muted">
        Values we expect to exist but have not yet filled (distinct from "not
        applicable"). Tracked per upstream docs/spec.md §16.6.4.
      </p>
      <ul class="bare">
        {dataGaps.map((g) => (
          <li>
            <code>{g.path}</code> <span class="muted">[{g.kind}]</span>
            {g.note && <div class="muted">{g.note}</div>}
            {g.source_hint && <div class="muted">source: {g.source_hint}</div>}
          </li>
        ))}
      </ul>
    </>
  )}

  <h2>Primary citation</h2>
  <p>{formatCite(entry.first_published)}</p>
  {entry.first_published.doi && (
    <p>
      DOI: <a href={`https://doi.org/${entry.first_published.doi}`} rel="noopener noreferrer">
        {entry.first_published.doi}
      </a>
    </p>
  )}
  {entry.first_published.url && (
    <p>URL: <a href={entry.first_published.url} rel="noopener noreferrer">{entry.first_published.url}</a></p>
  )}
  {entry.first_published.note && <p class="muted">{entry.first_published.note}</p>}

  {entry.corroborating_sources && entry.corroborating_sources.length > 0 && (
    <>
      <h2>Corroborating sources</h2>
      <ul>
        {entry.corroborating_sources.map((c) => (
          <li>
            {formatCite(c)}
            {c.doi && (
              <> DOI: <a href={`https://doi.org/${c.doi}`} rel="noopener noreferrer">{c.doi}</a></>
            )}
            {!c.doi && c.url && (
              <> &middot; <a href={c.url} rel="noopener noreferrer">link</a></>
            )}
            {c.note && <div class="muted">{c.note}</div>}
          </li>
        ))}
      </ul>
    </>
  )}

  {entry.notes && (
    <>
      <h2>Notes</h2>
      <p style="white-space: pre-wrap;">{entry.notes}</p>
    </>
  )}

  {entry.source_quotes && Object.keys(entry.source_quotes).length > 0 && (
    <>
      <h2>Source quotes (per-field provenance)</h2>
      <p class="muted">
        Every numerical value in this entry traces to a verbatim or paraphrased quote
        from a cited source.
      </p>
      <dl class="cycler">
        {Object.entries(entry.source_quotes).map(([field, quote]) => (
          <>
            <dt><code>{field}</code></dt>
            <dd><blockquote class="quote" style="white-space: pre-wrap;">{quote}</blockquote></dd>
          </>
        ))}
      </dl>
    </>
  )}
</Base>
