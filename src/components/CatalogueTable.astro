---
import { fmt, fmtBodies, fmtVinfMultiset, isFullyDefined } from "../lib/catalogue";
import type { CyclerEntry } from "../lib/types";

interface Props {
  entries: CyclerEntry[];
}

const { entries } = Astro.props;
const definedCount = entries.filter(isFullyDefined).length;

const completeness = (e: CyclerEntry): number => {
  // 0..1, fraction of "key" numerical fields that are non-null.
  const keys: Array<number | null> = [
    e.orbit_elements.a_au,
    e.orbit_elements.e,
    e.orbit_elements.perihelion_au,
    e.orbit_elements.aphelion_au,
    e.period.years,
    ...e.vinf_kms_at_encounters.map((v) => v.vinf_kms),
  ];
  const present = keys.filter((v) => v !== null && v !== undefined).length;
  return keys.length === 0 ? 0 : present / keys.length;
};
---
<div class="filter-bar" id="filter-bar">
  <div class="group" role="group" aria-label="Filter by encounter body">
    <span>Filter:</span>
    <label><input type="checkbox" class="planet-filter" value="V" checked /> Venus</label>
    <label><input type="checkbox" class="planet-filter" value="E" checked /> Earth</label>
    <label><input type="checkbox" class="planet-filter" value="M" checked /> Mars</label>
  </div>
  <span class="count" id="filter-count" aria-live="polite">{entries.length} entries</span>
  <span class="count" title="Orbits with all core fields present and no tracked known-unknowns">
    {definedCount} / {entries.length} fully defined
  </span>
</div>

<div style="overflow-x:auto;">
  <table class="catalogue" id="catalogue-table">
    <thead>
      <tr>
        <th data-sort="name" scope="col">Name</th>
        <th data-sort="bodies" scope="col">Bodies</th>
        <th data-sort="period" scope="col" aria-sort="ascending">Period (yr)</th>
        <th data-sort="a" scope="col">a (AU)</th>
        <th data-sort="e" scope="col">e</th>
        <th data-sort="vinf" scope="col">V∞ (km/s)</th>
        <th data-sort="completeness" scope="col">Data</th>
        <th data-sort="defined" scope="col">Defined</th>
        <th data-sort="validation" scope="col">Validation</th>
        <th data-sort="citation" scope="col">Source</th>
      </tr>
    </thead>
    <tbody>
      {entries
        .slice()
        .sort((a, b) => a.period.years - b.period.years)
        .map((e) => {
          const cite = e.first_published;
          const completePct = Math.round(completeness(e) * 100);
          const defined = isFullyDefined(e);
          return (
            <tr
              data-bodies={e.bodies.join(",")}
              data-name={e.name}
              data-period={e.period.years}
              data-a={e.orbit_elements.a_au ?? ""}
              data-e={e.orbit_elements.e ?? ""}
              data-vinf={Math.max(
                ...e.vinf_kms_at_encounters
                  .map((v) => v.vinf_kms)
                  .filter((x): x is number => x !== null),
                0,
              )}
              data-completeness={completePct}
              data-defined={defined ? 1 : 0}
              data-validation={e.validation_level ?? "V0"}
              data-citation={`${cite.authors[0] ?? "?"} ${cite.year}`}
            >
              <td><a href={`/cycler/${e.id}/`}>{e.name}</a></td>
              <td>{fmtBodies(e.bodies)}</td>
              <td class="right">{fmt(e.period.years, 2)}</td>
              <td class="right">{fmt(e.orbit_elements.a_au, 2)}</td>
              <td class="right">{fmt(e.orbit_elements.e, 3)}</td>
              <td>{fmtVinfMultiset(e.vinf_kms_at_encounters)}</td>
              <td class="right">{completePct}%</td>
              <td>{defined ? "yes" : <span class="muted">no</span>}</td>
              <td><span class="vlevel">{e.validation_level ?? "V0"}</span></td>
              <td>
                {cite.doi ? (
                  <a href={`https://doi.org/${cite.doi}`} rel="noopener noreferrer">
                    {cite.authors[0]?.split(",")[0] ?? "?"} {cite.year}
                  </a>
                ) : cite.url ? (
                  <a href={cite.url} rel="noopener noreferrer">
                    {cite.authors[0]?.split(",")[0] ?? "?"} {cite.year}
                  </a>
                ) : (
                  <span>{cite.authors[0]?.split(",")[0] ?? "?"} {cite.year}</span>
                )}
              </td>
            </tr>
          );
        })}
    </tbody>
  </table>
</div>

<script>
  // Planet filter + sort island. Vanilla TS — no framework.
  type SortKey =
    | "name"
    | "bodies"
    | "period"
    | "a"
    | "e"
    | "vinf"
    | "completeness"
    | "defined"
    | "validation"
    | "citation";

  const table = document.getElementById("catalogue-table") as HTMLTableElement | null;
  const countEl = document.getElementById("filter-count");
  const filterInputs = document.querySelectorAll<HTMLInputElement>(".planet-filter");

  if (!table) {
    // Hostile environment — bail.
  } else {
    const tbody = table.tBodies[0];
    if (!tbody) {
      // No rows; nothing to do.
    } else {
      const allRows = Array.from(tbody.rows);

      const applyFilter = () => {
        const checked = new Set(
          Array.from(filterInputs)
            .filter((i) => i.checked)
            .map((i) => i.value),
        );
        let visible = 0;
        for (const row of allRows) {
          const bodies = (row.dataset.bodies ?? "").split(",").filter(Boolean);
          // Show the row iff every body it encounters is in the checked set.
          // (If you uncheck Mars, you want to see cyclers that don't touch Mars.)
          const ok = bodies.length > 0 && bodies.every((b) => checked.has(b));
          row.classList.toggle("hidden", !ok);
          if (ok) visible++;
        }
        if (countEl) countEl.textContent = `${visible} of ${allRows.length} entries`;
      };

      for (const input of filterInputs) input.addEventListener("change", applyFilter);

      // Sort handling
      const headers = table.querySelectorAll<HTMLTableCellElement>("thead th[data-sort]");
      let currentSort: { key: SortKey; dir: "asc" | "desc" } = { key: "period", dir: "asc" };

      const sortValue = (row: HTMLTableRowElement, key: SortKey): string | number => {
        const raw = row.dataset[key] ?? "";
        // Numeric columns
        if (["period", "a", "e", "vinf", "completeness", "defined"].includes(key)) {
          const n = parseFloat(raw);
          return Number.isFinite(n) ? n : -Infinity;
        }
        return raw.toLowerCase();
      };

      const sortBy = (key: SortKey) => {
        const dir: "asc" | "desc" =
          currentSort.key === key && currentSort.dir === "asc" ? "desc" : "asc";
        currentSort = { key, dir };

        const rows = Array.from(tbody.rows);
        rows.sort((a, b) => {
          const va = sortValue(a, key);
          const vb = sortValue(b, key);
          if (va < vb) return dir === "asc" ? -1 : 1;
          if (va > vb) return dir === "asc" ? 1 : -1;
          return 0;
        });
        for (const r of rows) tbody.appendChild(r);

        for (const th of headers) {
          if (th.dataset.sort === key) {
            th.setAttribute("aria-sort", dir === "asc" ? "ascending" : "descending");
          } else {
            th.removeAttribute("aria-sort");
          }
        }
      };

      for (const th of headers) {
        th.addEventListener("click", () => {
          const key = th.dataset.sort as SortKey | undefined;
          if (key) sortBy(key);
        });
        th.tabIndex = 0;
        th.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            const key = th.dataset.sort as SortKey | undefined;
            if (key) sortBy(key);
          }
        });
      }

      applyFilter();
    }
  }
</script>
