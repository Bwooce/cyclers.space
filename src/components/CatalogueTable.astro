---
import {
  ORBIT_CLASS_LABEL,
  effectiveOrbitClass,
  fmt,
  fmtBodies,
  fmtIdentity,
  fmtVinfMultiset,
  formatValidityWindow,
  getEntryById,
  isFullyDefined,
  nReturnsValue,
} from "../lib/catalogue";
import type { CyclerEntry, OrbitClass } from "../lib/types";

interface Props {
  entries: CyclerEntry[];
}

const { entries } = Astro.props;
const definedCount = entries.filter(isFullyDefined).length;

const completeness = (e: CyclerEntry): number => {
  // 0..1, fraction of "key" numerical fields that are non-null.
  // For multi-arc/non-keplerian, a/e are structurally absent — don't penalise.
  const cls = e.cycler_class ?? "single-ellipse";
  const keys: Array<number | null> = [
    e.period?.years ?? null,
    ...(e.vinf_kms_at_encounters ?? []).map((v) => v.vinf_kms),
  ];
  const oe = e.orbit_elements;
  if (cls === "single-ellipse") {
    keys.push(oe?.a_au ?? null, oe?.e ?? null, oe?.perihelion_au ?? null, oe?.aphelion_au ?? null);
  } else if (cls === "multi-arc") {
    const inv = e.invariants;
    keys.push(inv?.aphelion_ratio ?? null, inv?.turn_ratio ?? null);
  } else if (cls === "non-keplerian") {
    const cr = oe?.cr3bp;
    keys.push(cr?.jacobi_constant ?? null, cr?.period_nd ?? null, cr?.stability_index ?? null);
  }
  const present = keys.filter((v) => v !== null && v !== undefined).length;
  return keys.length === 0 ? 0 : present / keys.length;
};

const fmtNReturns = (e: CyclerEntry): string => {
  const v = nReturnsValue(e);
  if (v === null) return "—";
  if (v === "infinite") return "∞";
  return String(v);
};

// Sort value for n_returns column: ∞ → +Infinity; missing → -Infinity.
const sortNReturns = (e: CyclerEntry): number => {
  const v = nReturnsValue(e);
  if (v === null) return -Infinity;
  if (v === "infinite") return Infinity;
  return v;
};

// Schema-v5 (2026-06-15): the four-class taxonomy gives epoch-locked rows a
// validity window. Add the column iff any epoch-locked row is present so the
// cyclers-only catalogue (during the migration window) keeps its compact shape.
const hasEpochLocked = entries.some((e) => effectiveOrbitClass(e) !== "cycler");
---
<div class="filter-bar" id="filter-bar">
  <div class="group" role="group" aria-label="Filter by encounter body">
    <span>Bodies:</span>
    <label><input type="checkbox" class="planet-filter" value="V" checked /> Venus</label>
    <label><input type="checkbox" class="planet-filter" value="E" checked /> Earth</label>
    <label><input type="checkbox" class="planet-filter" value="M" checked /> Mars</label>
  </div>
  <div class="group" role="group" aria-label="Filter by orbit class">
    <label for="class-filter">Class:</label>
    <select id="class-filter" class="class-filter">
      <option value="all">All</option>
      <option value="cycler">Cyclers</option>
      <option value="quasi_cycler">Quasi-cyclers</option>
      <option value="precursor_mga">Precursors</option>
      <option value="mga_tour">Tours</option>
    </select>
  </div>
  <div class="group" role="group" aria-label="Filter by validity window">
    <label for="window-filter">Window:</label>
    <select id="window-filter" class="window-filter" aria-describedby="window-filter-hint">
      <option value="all">All</option>
      <option value="open-now">Open now</option>
      <option value="future">Future</option>
      <option value="past">Past</option>
    </select>
    <span id="window-filter-hint" class="muted" style="font-size:0.75rem;">
      epoch-locked only
    </span>
  </div>
  <div class="group" role="group" aria-label="Filter by n returns">
    <label for="nreturns-min">n_returns:</label>
    <input type="number" id="nreturns-min" class="nreturns-min" min="0" step="1" placeholder="min" inputmode="numeric" />
    <span class="muted">–</span>
    <input type="number" id="nreturns-max" class="nreturns-max" min="0" step="1" placeholder="max" inputmode="numeric" />
  </div>
  <span class="count" id="filter-count" aria-live="polite">{entries.length} entries</span>
  <span class="count" title="Orbits with all core fields present and no tracked known-unknowns">
    {definedCount} / {entries.length} fully defined
  </span>
</div>

<div style="overflow-x:auto;">
  <table class="catalogue" id="catalogue-table">
    <thead>
      <tr>
        <th data-sort="name" scope="col">Name</th>
        <th data-sort="orbit_class" scope="col">Class</th>
        <th data-sort="bodies" scope="col">Bodies</th>
        <th data-sort="class" scope="col">Struct</th>
        <th data-sort="period" scope="col" aria-sort="ascending">Period (yr)</th>
        <th data-sort="identity" scope="col">Identity</th>
        <th data-sort="vinf" scope="col">V∞ (km/s)</th>
        <th data-sort="nreturns" scope="col">Returns</th>
        {hasEpochLocked && (
          <th data-sort="validity" scope="col">Validity</th>
        )}
        <th data-sort="completeness" scope="col">Data</th>
        <th data-sort="defined" scope="col">Defined</th>
        <th data-sort="validation" scope="col">Validation</th>
        <th data-sort="citation" scope="col">Source</th>
      </tr>
    </thead>
    <tbody>
      {entries
        .slice()
        .sort((a, b) => (a.period?.years ?? Infinity) - (b.period?.years ?? Infinity))
        .map((e) => {
          const cite = e.first_published;
          const completePct = Math.round(completeness(e) * 100);
          const defined = isFullyDefined(e);
          const cls = e.cycler_class ?? "single-ellipse";
          const clsShort = cls === "single-ellipse" ? "SE" : cls === "multi-arc" ? "MA" : "NK";
          const orbitClass: OrbitClass = effectiveOrbitClass(e);
          const orbitClassLabel = ORBIT_CLASS_LABEL[orbitClass];
          const identity = fmtIdentity(e);
          const validityStr = formatValidityWindow(e.validity_window);
          const insertsInto = e.inserts_into ?? null;
          const insertsTarget = insertsInto ? getEntryById(insertsInto) : null;
          const launchEpoch = e.launch_epoch ?? null;
          // Sort-value for the validity column: start date (lex order) when present,
          // empty string otherwise (sorts to the bottom of asc).
          const validitySort = e.validity_window?.start ?? "";
          return (
            <tr
              data-bodies={e.bodies.join(",")}
              data-name={e.name}
              data-class={cls}
              data-orbit-class={orbitClass}
              data-validity-start={e.validity_window?.start ?? ""}
              data-validity-end={e.validity_window?.end ?? ""}
              data-nreturns={sortNReturns(e)}
              data-period={e.period?.years ?? ""}
              data-identity={identity}
              data-vinf={Math.max(
                ...(e.vinf_kms_at_encounters ?? [])
                  .map((v) => v.vinf_kms)
                  .filter((x): x is number => x !== null),
                0,
              )}
              data-validity={validitySort}
              data-completeness={completePct}
              data-defined={defined ? 1 : 0}
              data-validation={e.validation_level ?? "V0"}
              data-citation={`${cite.authors[0] ?? "?"} ${cite.year}`}
            >
              <td><a href={`/cycler/${e.id}/`}>{e.name}</a></td>
              <td>
                <span
                  class={`orbit-class-badge oc-${orbitClass}`}
                  title={orbitClassLabel}
                >
                  {orbitClassLabel}
                </span>
              </td>
              <td>{fmtBodies(e.bodies)}</td>
              <td><span class={`cls-badge cls-${cls.replace("-", "")}`} title={cls}>{clsShort}</span></td>
              <td class="right">{e.period ? fmt(e.period.years, 2) : "—"}</td>
              <td class="identity">{identity}</td>
              <td>{fmtVinfMultiset(e.vinf_kms_at_encounters)}</td>
              <td class="right">{fmtNReturns(e)}</td>
              {hasEpochLocked && (
                <td class="validity-col">
                  {validityStr ? (
                    <span
                      class="validity-window"
                      title={launchEpoch ? `Launch epoch: ${launchEpoch}` : undefined}
                    >
                      {validityStr}
                    </span>
                  ) : (
                    <span class="muted">—</span>
                  )}
                  {insertsInto && (
                    <div class="muted" style="font-size:0.75rem;">
                      inserts into
                      {" "}
                      {insertsTarget ? (
                        <a href={`/cycler/${insertsInto}/`}>{insertsTarget.name}</a>
                      ) : (
                        <code>{insertsInto}</code>
                      )}
                    </div>
                  )}
                </td>
              )}
              <td class="right">{completePct}%</td>
              <td>{defined ? "yes" : <span class="muted">no</span>}</td>
              <td><span class="vlevel">{e.validation_level ?? "V0"}</span></td>
              <td>
                {cite.doi ? (
                  <a href={`https://doi.org/${cite.doi}`} rel="noopener noreferrer">
                    {cite.authors[0]?.split(",")[0] ?? "?"} {cite.year}
                  </a>
                ) : cite.url ? (
                  <a href={cite.url} rel="noopener noreferrer">
                    {cite.authors[0]?.split(",")[0] ?? "?"} {cite.year}
                  </a>
                ) : (
                  <span>{cite.authors[0]?.split(",")[0] ?? "?"} {cite.year}</span>
                )}
              </td>
            </tr>
          );
        })}
    </tbody>
  </table>
</div>

<script>
  // Planet filter + class filter + window filter + n_returns range + sort island.
  // Vanilla TS — no framework.
  type SortKey =
    | "name"
    | "orbit_class"
    | "bodies"
    | "class"
    | "period"
    | "identity"
    | "vinf"
    | "nreturns"
    | "validity"
    | "completeness"
    | "defined"
    | "validation"
    | "citation";

  const table = document.getElementById("catalogue-table") as HTMLTableElement | null;
  const countEl = document.getElementById("filter-count");
  const filterInputs = document.querySelectorAll<HTMLInputElement>(".planet-filter");
  const classSelect = document.getElementById("class-filter") as HTMLSelectElement | null;
  const windowSelect = document.getElementById("window-filter") as HTMLSelectElement | null;
  const nMinInput = document.getElementById("nreturns-min") as HTMLInputElement | null;
  const nMaxInput = document.getElementById("nreturns-max") as HTMLInputElement | null;

  // The "Window" and "n_returns" filters are meaningful only when the class is
  // not Cyclers (strict cyclers have no window and infinite returns). When the
  // user selects Class=Cyclers we grey them out + zero them, but the filter
  // state remains "all" so a switch back to All restores prior intent.
  const setEpochOnlyFiltersEnabled = (enabled: boolean) => {
    for (const el of [windowSelect, nMinInput, nMaxInput] as Array<HTMLElement | null>) {
      if (!el) continue;
      if (enabled) {
        el.removeAttribute("disabled");
        el.classList.remove("disabled");
      } else {
        el.setAttribute("disabled", "disabled");
        el.classList.add("disabled");
      }
    }
  };

  if (!table) {
    // Hostile environment — bail.
  } else {
    const tbody = table.tBodies[0];
    if (!tbody) {
      // No rows; nothing to do.
    } else {
      const allRows = Array.from(tbody.rows);
      // Today as ISO date for the window classifier; matches the schema (ISO-8601
      // lexicographic sort works).
      const todayIso = new Date().toISOString().slice(0, 10);

      const classifyWindow = (start: string, end: string): "open-now" | "past" | "future" | "unknown" => {
        if (!start || !end) return "unknown";
        if (todayIso < start) return "future";
        if (todayIso > end) return "past";
        return "open-now";
      };

      const applyFilter = () => {
        const checked = new Set(
          Array.from(filterInputs)
            .filter((i) => i.checked)
            .map((i) => i.value),
        );
        const classFilter = classSelect?.value ?? "all";
        const windowFilter = (windowSelect?.value ?? "all") as
          | "all"
          | "open-now"
          | "past"
          | "future";
        const minStr = nMinInput?.value.trim() ?? "";
        const maxStr = nMaxInput?.value.trim() ?? "";
        const min = minStr === "" ? null : parseInt(minStr, 10);
        const max = maxStr === "" ? null : parseInt(maxStr, 10);

        // Grey out window+n_returns when the user has fixed Class=Cyclers.
        setEpochOnlyFiltersEnabled(classFilter !== "cycler");

        let visible = 0;
        for (const row of allRows) {
          const bodies = (row.dataset.bodies ?? "").split(",").filter(Boolean);
          // Show the row iff every body it encounters is in the checked set.
          // (If you uncheck Mars, you want to see cyclers that don't touch Mars.)
          const bodiesOk = bodies.length > 0 && bodies.every((b) => checked.has(b));

          const orbitClass = row.dataset.orbitClass ?? "cycler";
          const classOk = classFilter === "all" || orbitClass === classFilter;

          // Window filter only applies to epoch-locked rows; Cyclers fail any
          // non-"all" window filter by design (they have no window). When the
          // user selects Class=Cyclers we've already disabled the input, so its
          // value stays as last set; honour it anyway for correctness.
          let windowOk = true;
          if (windowFilter !== "all") {
            if (orbitClass === "cycler") {
              windowOk = false;
            } else {
              const w = classifyWindow(
                row.dataset.validityStart ?? "",
                row.dataset.validityEnd ?? "",
              );
              windowOk = w === windowFilter;
            }
          }

          // n_returns range. data-nreturns is +Infinity for cyclers,
          // -Infinity for unknown; the comparison logic handles both.
          let returnsOk = true;
          if (min !== null || max !== null) {
            const v = parseFloat(row.dataset.nreturns ?? "");
            if (!Number.isFinite(v)) {
              // -Infinity / NaN → unknown count; fail any explicit bound.
              if (v === -Infinity || Number.isNaN(v)) {
                returnsOk = false;
              } else if (v === Infinity) {
                // ∞ ≥ any min; ∞ ≤ no finite max.
                returnsOk = max === null;
              }
            } else {
              if (min !== null && v < min) returnsOk = false;
              if (max !== null && v > max) returnsOk = false;
            }
          }

          const ok = bodiesOk && classOk && windowOk && returnsOk;
          row.classList.toggle("hidden", !ok);
          if (ok) visible++;
        }
        if (countEl) countEl.textContent = `${visible} of ${allRows.length} entries`;
      };

      for (const input of filterInputs) input.addEventListener("change", applyFilter);
      classSelect?.addEventListener("change", applyFilter);
      windowSelect?.addEventListener("change", applyFilter);
      nMinInput?.addEventListener("input", applyFilter);
      nMaxInput?.addEventListener("input", applyFilter);

      // Sort handling
      const headers = table.querySelectorAll<HTMLTableCellElement>("thead th[data-sort]");
      let currentSort: { key: SortKey; dir: "asc" | "desc" } = { key: "period", dir: "asc" };

      const sortValue = (row: HTMLTableRowElement, key: SortKey): string | number => {
        const raw = row.dataset[key === "orbit_class" ? "orbitClass" : key] ?? "";
        // Numeric columns
        if (["period", "vinf", "nreturns", "completeness", "defined"].includes(key)) {
          const n = parseFloat(raw);
          return Number.isFinite(n) ? n : -Infinity;
        }
        return raw.toLowerCase();
      };

      const sortBy = (key: SortKey) => {
        const dir: "asc" | "desc" =
          currentSort.key === key && currentSort.dir === "asc" ? "desc" : "asc";
        currentSort = { key, dir };

        const rows = Array.from(tbody.rows);
        rows.sort((a, b) => {
          const va = sortValue(a, key);
          const vb = sortValue(b, key);
          if (va < vb) return dir === "asc" ? -1 : 1;
          if (va > vb) return dir === "asc" ? 1 : -1;
          return 0;
        });
        for (const r of rows) tbody.appendChild(r);

        for (const th of headers) {
          if (th.dataset.sort === key) {
            th.setAttribute("aria-sort", dir === "asc" ? "ascending" : "descending");
          } else {
            th.removeAttribute("aria-sort");
          }
        }
      };

      for (const th of headers) {
        th.addEventListener("click", () => {
          const key = th.dataset.sort as SortKey | undefined;
          if (key) sortBy(key);
        });
        th.tabIndex = 0;
        th.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            const key = th.dataset.sort as SortKey | undefined;
            if (key) sortBy(key);
          }
        });
      }

      applyFilter();
    }
  }
</script>
