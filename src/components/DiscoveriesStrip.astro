---
// "Discovered here" strip (#462): pins this project's genuine, original
// discoveries to the top of the catalogue so they are not buried in catalogue
// order alongside reproductions and literature anchors. Data-driven via
// isProjectDiscovery — future discovery rows appear automatically, no edits.
//
// Honest, understated copy: "Discovered by this project". No superlatives.
import { fmtBodies } from "../lib/catalogue";
import type { CyclerEntry } from "../lib/types";

interface Props {
  discoveries: CyclerEntry[];
}

const { discoveries } = Astro.props;
---
{discoveries.length > 0 && (
  <section class="discoveries" aria-labelledby="discoveries-heading">
    <h2 id="discoveries-heading">Discovered by this project</h2>
    <p class="muted discoveries-intro">
      {discoveries.length === 1 ? "This orbit was" : `These ${discoveries.length} orbits were`}
      {" "}
      first identified by this project's own search campaign — not reproduced from,
      or corroborated by, the published record. Every other catalogue row is sourced
      from the literature.
    </p>
    <ul class="discoveries-list">
      {discoveries.map((e) => {
        const vlevel = e.validation_level ?? "V0";
        return (
          <li class="discovery-card">
            <a class="discovery-name" href={`/cycler/${e.id}/`}>{e.name}</a>
            <div class="discovery-meta">
              <span class="vlevel" title={`Validation level ${vlevel}`}>{vlevel}</span>
              <span class="discovery-bodies">{fmtBodies(e.bodies)}</span>
              {e.period?.years != null && (
                <span class="discovery-period">{e.period.years.toFixed(2)} yr</span>
              )}
              <span class="discovery-year muted">
                {e.first_published?.year ?? ""}
              </span>
            </div>
          </li>
        );
      })}
    </ul>
  </section>
)}
